/blueprint/lean_decls
/blueprint/web/
/blueprint/print/
/blueprint/src/*.paux

# Assembled local site (docbuild/build-site.py output)
/site/

# docbuild sub-project build dir
docbuild/.lake/

# junk
f.txt

# Claude
.claude/plans

# env
.envrc

